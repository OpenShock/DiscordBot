  "components": {
    "schemas": {
      "AuthUserDto": {
        "required": [
          "discordId",
          "name",
          "avatar"
        ],
        "type": "object",
        "properties": {
          "discordId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatar": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ConsentRequest": {
        "required": [
          "allowRoomShocks",
          "roomMaxIntensity",
          "roomMaxDurationMs"
        ],
        "type": "object",
        "properties": {
          "allowRoomShocks": {
            "type": "boolean"
          },
          "roomMaxIntensity": {
            "type": "integer",
            "format": "uint8"
          },
          "roomMaxDurationMs": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ControlRequestDto": {
        "required": [
          "targetDiscordId",
          "instanceId",
          "intensity",
          "duration",
          "type",
          "mode"
        ],
        "type": "object",
        "properties": {
          "targetDiscordId": {
            "type": "string"
          },
          "instanceId": {
            "type": "string"
          },
          "intensity": {
            "type": "integer",
            "format": "uint8"
          },
          "duration": {
            "type": "number",
            "format": "float"
          },
          "type": {
            "$ref": "#/components/schemas/ControlType"
          },
          "mode": {
            "$ref": "#/components/schemas/ShockMode"
          }
        }
      },
      "ControlResponseDto": {
        "required": [
          "intensity",
          "durationSeconds"
        ],
        "type": "object",
        "properties": {
          "intensity": {
            "type": "integer",
            "format": "uint8"
          },
          "durationSeconds": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "ControlType": {
        "enum": [
          "Stop",
          "Shock",
          "Vibrate",
          "Sound"
        ],
        "type": "string"
      },
      "DevTokenRequest": {
        "required": [
          "discordId",
          "name"
        ],
        "type": "object",
        "properties": {
          "discordId": {
            "type": "string"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "DevTokenResponse": {
        "required": [
          "jwt"
        ],
        "type": "object",
        "properties": {
          "jwt": {
            "type": "string"
          }
        }
      },
      "LinkRequest": {
        "required": [
          "apiToken",
          "apiServer"
        ],
        "type": "object",
        "properties": {
          "apiToken": {
            "type": "string"
          },
          "apiServer": {
            "type": "string"
          }
        }
      },
      "LinkResponse": {
        "required": [
          "openShockName"
        ],
        "type": "object",
        "properties": {
          "openShockName": {
            "type": "string"
          }
        }
      },
      "MeResponse": {
        "required": [
          "linked",
          "allowRoomShocks",
          "roomMaxIntensity",
          "roomMaxDurationMs"
        ],
        "type": "object",
        "properties": {
          "linked": {
            "type": "boolean"
          },
          "allowRoomShocks": {
            "type": "boolean"
          },
          "roomMaxIntensity": {
            "type": "integer",
            "format": "uint8"
          },
          "roomMaxDurationMs": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "OpenShockProblem": {
        "required": [
          "type",
          "title"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          },
          "requestId": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SetShockersRequest": {
        "required": [
          "enabledIds"
        ],
        "type": "object",
        "properties": {
          "enabledIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "ShockerDto": {
        "required": [
          "id",
          "name",
          "hubName",
          "enabled"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "hubName": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      },
      "ShockMode": {
        "enum": [
          "Random",
          "All"
        ],
        "type": "string"
      },
      "TokenRequest": {
        "required": [
          "code"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          }
        }
      },
      "TokenResponse": {
        "required": [
          "discordAccessToken",
          "jwt",
          "user"
        ],
        "type": "object",
        "properties": {
          "discordAccessToken": {
            "type": "string"
          },
          "jwt": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        }
      },
      "WhitelistEntryDto": {
        "required": [
          "discordId"
        ],
        "type": "object",
        "properties": {
          "discordId": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Control"
    },
    {
      "name": "Shocker"
    },
    {
      "name": "User"
    },
    {
      "name": "Whitelist"
    }
  ]
}
