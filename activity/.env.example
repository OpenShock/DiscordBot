# Discord Application (client) ID for the Activity. Public — safe to ship to the browser.
# Exposed to app code via SvelteKit's $env/static/public (PUBLIC_ prefix).
PUBLIC_DISCORD_CLIENT_ID=1096380937496969326

# Base path for the backend API. In production the Discord proxy maps "/api" to the API host,
# and the API serves its routes at root (Discord strips the "/api" prefix).
PUBLIC_API_BASE=/api

# Local dev/tooling only (read in vite.config.ts and scripts/regenerate-api.js, which run in Node and
# can't use SvelteKit's $env): where `vite dev`/`vite preview` proxies "/api" (and the SignalR
# WebSocket), and where `pnpm regen-api` fetches the OpenAPI document. Defaults to http://localhost:5000.
VITE_API_PROXY_TARGET=http://localhost:5000
