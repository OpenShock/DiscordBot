# Discord Application (client) ID for the Activity. Public — safe to ship to the browser.
VITE_DISCORD_CLIENT_ID=1096380937496969326

# Base path for the backend API. In production the Discord proxy maps "/api" to the API host,
# and the API serves its routes at root (Discord strips the "/api" prefix).
VITE_API_BASE=/api

# Local dev only: where `vite dev`/`vite preview` proxies "/api" (and the SignalR WebSocket).
# Point this at your locally running OpenShock.Activity.Api. Defaults to http://localhost:5199.
VITE_API_PROXY_TARGET=http://localhost:5199
